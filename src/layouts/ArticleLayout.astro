---
import BaseLayout from './BaseLayout.astro';
import ArticleMeta from '../components/ArticleMeta.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, description, lastVerified, targetVersion, estimatedMinutes } = article.data;
---

<BaseLayout title={`${title} — Claude Code 写本`} description={description}>
  <article class="article-prose">
    <Breadcrumb chapterId={article.data.chapter} articleTitle={title} />
    
    <h1 class="article-title">{title}</h1>
    <p class="article-subtitle">{description}</p>

    <ArticleMeta
      lastVerified={lastVerified}
      targetVersion={targetVersion}
      estimatedMinutes={estimatedMinutes}
    />

    <div class="article-body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .article-prose {
    max-width: var(--content-width);
    margin: 48px auto 96px;
    padding: 0 24px;
  }

  .article-title {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 500;
    color: var(--sepia);
    line-height: 1.05;
    margin: 0 0 14px;
    letter-spacing: -0.005em;
  }

  .article-subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 19px;
    color: var(--ink-soft);
    margin: 0 0 28px;
  }

  /* リード段落のドロップキャップ */
  .article-body :global(p:first-of-type)::first-letter {
    font-family: var(--font-display);
    font-size: 64px;
    font-weight: 500;
    float: left;
    line-height: 0.85;
    margin: 6px 10px 0 0;
    color: var(--crimson);
  }
</style>