---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// h2 と h3 だけを取り出す（h1 はタイトル、h4 以降は深すぎ）
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{tocHeadings.length > 0 && (
  <aside class="toc" aria-label="この頁の目次">
    <div class="toc-label">この頁の目次</div>
    <ul class="toc-list">
      {tocHeadings.map((heading) => (
        <li class:list={['toc-item', `depth-${heading.depth}`]}>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))}
    </ul>
  </aside>
)}

<style>
  .toc {
    font-family: var(--font-jp);
    font-size: 13px;
    position: sticky;
    top: 32px;
    align-self: start;
    height: fit-content;
    max-height: calc(100vh - 64px);
    overflow-y: auto;
  }

  .toc-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 12px;
    color: var(--gold);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--rule-soft);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-item {
    margin: 0;
    border-left: 1px solid var(--rule-soft);
  }

  .toc-item.depth-3 {
    padding-left: 12px;
  }

  .toc-item a {
    display: block;
    padding: 7px 14px;
    color: var(--ink-mute);
    text-decoration: none;
    transition: all 0.2s;
    font-size: 13px;
    line-height: 1.5;
    border-bottom: none;
  }

  .toc-item a:hover {
    color: var(--sepia);
    border-bottom: none;
  }

  .toc-item.depth-3 a {
    font-size: 12px;
    color: var(--ink-mute);
  }
</style>