---
// このコンポーネントは現時点ではプロパティを受け取らない
---

<header class="site-header">
    <a href="/ja/" class="brand">
      <span class="brand-mark">C</span>
      <span class="brand-text">
        <span class="brand-name">Claude Code 写本</span>
        <span class="brand-sub">Codex Claudia &middot; A scribe's guide</span>
      </span>
    </a>
    <nav class="top-nav">
      <a href="/ja/">学習</a>
      <a href="/about">このサイトについて</a>
    </nav>
  </header>
  
  <style>
    .site-header {
      padding: 28px 56px 24px;
      border-bottom: 1px solid var(--rule);
      background: linear-gradient(to bottom, rgba(243, 233, 210, 0.7), rgba(243, 233, 210, 0));
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
  
    .brand {
      display: flex;
      align-items: baseline;
      gap: 14px;
      text-decoration: none;
      border: none;
    }
  
    .brand:hover {
      border: none;
    }
  
    .brand-mark {
      width: 38px;
      height: 38px;
      border: 1.5px solid var(--sepia);
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 22px;
      color: var(--sepia);
      font-style: italic;
      transform: translateY(6px);
      background: var(--bg-card);
    }
  
    .brand-text {
      display: flex;
      flex-direction: column;
      line-height: 1;
    }
  
    .brand-name {
      font-family: var(--font-display);
      font-size: 28px;
      font-weight: 500;
      color: var(--sepia);
      letter-spacing: 0.02em;
    }
  
    .brand-sub {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 13px;
      color: var(--ink-mute);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin-top: 6px;
    }
  
    .top-nav {
      display: flex;
      gap: 32px;
      align-items: center;
    }
  
    .top-nav a {
      font-family: var(--font-jp);
      font-size: 14px;
      color: var(--ink-soft);
      border: none;
      letter-spacing: 0.05em;
      transition: color 0.2s;
    }
  
    .top-nav a:hover {
      color: var(--crimson);
      border: none;
    }
  </style>